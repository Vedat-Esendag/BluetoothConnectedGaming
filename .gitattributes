# Game assets under assets/ are binary; store them with Git LFS. Platform
# launcher icons live under android/ ios/ web/ etc. and must stay in normal git
# so builds and CI work without fetching LFS objects.
assets/**/*.png  filter=lfs diff=lfs merge=lfs -text
assets/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
assets/**/*.gif  filter=lfs diff=lfs merge=lfs -text
assets/**/*.webp filter=lfs diff=lfs merge=lfs -text
assets/**/*.mp3  filter=lfs diff=lfs merge=lfs -text
assets/**/*.wav  filter=lfs diff=lfs merge=lfs -text
assets/**/*.ogg  filter=lfs diff=lfs merge=lfs -text
assets/**/*.ttf  filter=lfs diff=lfs merge=lfs -text
assets/**/*.otf  filter=lfs diff=lfs merge=lfs -text

# Normalize line endings for source.
*.dart text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
